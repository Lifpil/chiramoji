<Window x:Class="BlindTouchOled.Views.ImageCropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="画像トリミング"
        Width="920"
        MinWidth="920"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFF9F8F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#FFE3D6D2"
                    BorderThickness="1"
                    Padding="14">
                <StackPanel>
                    <TextBlock Text="ズーム" Margin="0,0,0,6"/>
                    <Slider x:Name="ZoomSlider" Minimum="0.25" Maximum="4" Value="1" ValueChanged="OnSliderChanged"/>
                    <TextBlock Text="横位置" Margin="0,14,0,6"/>
                    <Slider x:Name="OffsetXSlider" Minimum="-100" Maximum="100" Value="0" ValueChanged="OnSliderChanged"/>
                    <TextBlock Text="縦位置" Margin="0,14,0,6"/>
                    <Slider x:Name="OffsetYSlider" Minimum="-100" Maximum="100" Value="0" ValueChanged="OnSliderChanged"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#FFE3D6D2"
                    BorderThickness="1"
                    Padding="14">
                <StackPanel>
                    <TextBlock Text="プレビュー"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <Border
                            Background="#FF1D1D1D"
                            CornerRadius="8"
                            HorizontalAlignment="Center"
                            Padding="8">
                        <Image x:Name="PreviewImage"
                               Width="512"
                               Height="128"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="キャンセル"
                    Width="100"
                    Margin="0,0,10,0"
                    Click="OnCancel"/>
            <Button Content="OK"
                    Width="100"
                    Click="OnOk"/>
        </StackPanel>
    </Grid>
</Window>
